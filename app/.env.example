NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# The public HTTPS origin of this app (no trailing slash).
# Used by the Proxy auth guard to build the post-login callback URL so the
# Entrepreneuria login page always receives the trusted https:// origin even
# when the deployment's reverse proxy terminates TLS before reaching Next.js.
# Must exactly match one of the entries in TRUSTED_ENTREPRENEURIA_APPS in
# lib/auth/shared-session.ts — i.e. https://directorium.entrepreneuria.io
NEXT_PUBLIC_APP_URL=https://directorium.entrepreneuria.io

# Directorium consumes the global Entrepreneuria Supabase auth session.
# The shared auth cookie is entrepreneuria-auth-token on .entrepreneuria.io.
